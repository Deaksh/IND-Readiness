# Copy to .env and fill in. Loaded automatically on startup (backend/.env).

# --- Admin (required for /api/admin/login and admin UI) ---
ADMIN_PASSWORD=
# Optional: restrict login to this email; if unset, any email works with correct password.
ADMIN_EMAIL=
# Long random secret for X-Admin-Key header (bypasses JWT).
ADMIN_API_KEY=
# Optional; defaults to ADMIN_API_KEY or a dev fallback. Use a strong secret in production.
ADMIN_JWT_SECRET=

# --- Database ---
# Default: sqlite:///./submissions.db (relative to cwd when uvicorn runs)
# Render Postgres: set DATABASE_URL from the dashboard (postgres://… is rewritten to psycopg3).
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname

# --- Transactional email (configure at least one) ---
# Sender address (must match what your provider authorizes). SMTP_FROM is accepted as alias.
EMAIL_FROM=
EMAIL_FROM_NAME=Beacon IND Readiness
# auto | smtp | brevo | resend — set smtp to force SMTP if API keys are also present
EMAIL_PROVIDER=auto
# Brevo (Sendinblue) HTTPS API — preferred on hosts that block SMTP
BREVO_API_KEY=
# Or Resend
RESEND_API_KEY=
# Or SMTP (port 587 + STARTTLS, or 465 + SSL).
# Brevo relay: SMTP_HOST=smtp-relay.brevo.com — SMTP_USER = your Brevo account email;
# SMTP_PASSWORD = SMTP key from Brevo dashboard (not Gmail password).
# If you only set SMTP_FROM and no EMAIL_FROM, the app uses SMTP_FROM as the From: address.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# For implicit TLS (e.g. port 465), set:
# SMTP_USE_SSL=1

# --- CORS / app (optional) ---
# CORS_ORIGINS=https://your-frontend.vercel.app
# CALENDLY_URL=https://calendly.com/...
